{"cells":[{"cell_type":"markdown","source":["#CẤU HÌNH HỆ THỐNG VÀ GIẢI NÉN DỮ LIỆU"],"metadata":{"id":"PEa5mX5LUBji"}},{"cell_type":"code","source":["import cv2\n","import numpy as np\n","import os\n","import zipfile\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from sklearn.cluster import KMeans\n","from sklearn.neighbors import KNeighborsClassifier\n","from sklearn.model_selection import train_test_split\n","from sklearn.metrics import classification_report, accuracy_score, confusion_matrix\n","from google.colab import files"],"metadata":{"id":"IxmUSpB1V6zq","executionInfo":{"status":"ok","timestamp":1768018585207,"user_tz":-420,"elapsed":6653,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":["#CẤU HÌNH ĐẦU VÀO\n"],"metadata":{"id":"CLKEygBFV-pI","executionInfo":{"status":"ok","timestamp":1768018793984,"user_tz":-420,"elapsed":5,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["ZIP_FILENAME = 'Dataset tranh.zip'\n","EXTRACT_PATH = '/content/dataset_extracted'"],"metadata":{"id":"pmqqR8uyWFYC","executionInfo":{"status":"ok","timestamp":1768018796184,"user_tz":-420,"elapsed":151,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["TEST_IMAGE_NAME = 'test.jpg'\n","\n","print(\" Start to run...\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"HiFC3AS_WgbS","executionInfo":{"status":"ok","timestamp":1768018798030,"user_tz":-420,"elapsed":35,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"outputId":"29db65b5-0d0e-49e7-fad2-c1d759bc6174"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":[" Start to run...\n"]}]},{"cell_type":"markdown","source":["##1. Giải nén dữ liệu"],"metadata":{"id":"RE-WrEo2XWEk"}},{"cell_type":"code","source":["if os.path.exists(ZIP_FILENAME):\n","    print(f\"--> Đã tìm thấy file '{ZIP_FILENAME}'. Đang giải nén...\")\n","    with zipfile.ZipFile(ZIP_FILENAME, 'r') as zip_ref:\n","        zip_ref.extractall(EXTRACT_PATH)\n","    print(\"--> Giải nén thành công!\")\n","else:\n","    print(f\"Không tìm thấy file '{ZIP_FILENAME}'. Vui lòng upload file zip vào mục Files.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bH5smVhwXYV4","executionInfo":{"status":"ok","timestamp":1768018811182,"user_tz":-420,"elapsed":152,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"outputId":"3ddedb49-1d5d-49f9-a3c2-48cefb9aaab4"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["--> Đã tìm thấy file 'Dataset tranh.zip'. Đang giải nén...\n","--> Giải nén thành công!\n"]}]},{"cell_type":"markdown","source":["##2. Tự động tìm đường dẫn gốc chứa ảnh"],"metadata":{"id":"6sfVeEheXpmS"}},{"cell_type":"code","source":["def find_data_root(start_path):\n","    for root, dirs, files in os.walk(start_path):\n","        for d in dirs:\n","            # Tìm thư mục đặc trưng của Nguyễn Gia Trí để xác định gốc\n","            if \"NguyenGiaTri\" in d or \"1.jpg\" in d:\n","                return root\n","    return start_path\n","\n","BASE_PATH = find_data_root(EXTRACT_PATH)\n","print(f\"--> Đường dẫn gốc dữ liệu: {BASE_PATH}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"UdaZPgpxXwu9","executionInfo":{"status":"ok","timestamp":1768018814173,"user_tz":-420,"elapsed":9,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"outputId":"5706d764-2d31-4d65-e1a1-80d4457883e4"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["--> Đường dẫn gốc dữ liệu: /content/dataset_extracted/Dataset DS\n"]}]},{"cell_type":"markdown","source":["##3. Định nghĩa thông tin"],"metadata":{"id":"XzSNZUsBX-We"}},{"cell_type":"code","source":["dataset_config = {\n","    \"NguyenGiaTri\": {\n","        \"keywords\": [\"NguyenGiaTri\", \"1.jpg\"],\n","        \"label\": 1,\n","        \"name\": \"Nguyễn Gia Trí\",\n","        \"style\": \"Sơn mài (Vàng son, then, vỏ trứng - Gam màu nóng, trầm)\",\n","        \"avg_edge\": 0, # Sẽ cập nhật sau\n","        \"path\": None\n","    },\n","    \"NguyenTuongLan\": {\n","        \"keywords\": [\"NguyenTuongLan\", \"2.jpg\"],\n","        \"label\": 2,\n","        \"name\": \"Nguyễn Tường Lân\",\n","        \"style\": \"Đa phong cách (Huyền ảo, thơ mộng, gam màu nhẹ)\",\n","        \"avg_edge\": 0,\n","        \"path\": None\n","    },\n","    \"ToNgocVan\": {\n","        \"keywords\": [\"ToNgocVan\", \"3.jpg\"],\n","        \"label\": 3,\n","        \"name\": \"Tô Ngọc Vân\",\n","        \"style\": \"Sơn dầu (Lãng mạn, ánh sáng phương Tây, gam trắng/xanh)\",\n","        \"avg_edge\": 0,\n","        \"path\": None\n","    },\n","    \"TranVanCan\": {\n","        \"keywords\": [\"TranVanCan\", \"4.jpg\"],\n","        \"label\": 4,\n","        \"name\": \"Trần Văn Cẩn\",\n","        \"style\": \"Hiện thực (Khắc gỗ, nét khỏe, mảng màu phẳng)\",\n","        \"avg_edge\": 0,\n","        \"path\": None\n","    }\n","}\n"],"metadata":{"id":"NmAZ8wRtYAgP","executionInfo":{"status":"ok","timestamp":1768018790923,"user_tz":-420,"elapsed":13,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["#Tự động map đường dẫn vào thực tế config"],"metadata":{"id":"knUOKHf1YKuB"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["from os.path import exists\n","for key, config in dataset_config.items():\n","  if os.path.exists(BASE_PATH):\n","    for item in os.listdir(BASE_PATH):\n","            if any(k in item for k in config[\"keywords\"]) and os.path.isdir(os.path.join(BASE_PATH, item)):\n","                config[\"path\"] = os.path.join(BASE_PATH, item)\n","                print(f\" Đã nạp dữ liệu: {config['name']}\")\n","                break"],"metadata":{"id":"cQRT6deKYPYz","executionInfo":{"status":"ok","timestamp":1768018823153,"user_tz":-420,"elapsed":8,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"0b1fcfab-4bd1-474d-fbb3-bac228a78baa"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":[" Đã nạp dữ liệu: Nguyễn Gia Trí\n"," Đã nạp dữ liệu: Nguyễn Tường Lân\n"," Đã nạp dữ liệu: Tô Ngọc Vân\n"," Đã nạp dữ liệu: Trần Văn Cẩn\n"]}]},{"cell_type":"markdown","source":["TRÍCH XUẤT ĐẶC TRƯNG CỦA DỮ LIỆU"],"metadata":{"id":"rnnlRZljYnJk"}},{"cell_type":"code","source":["def calculate_edge_density(img):\n","    \"\"\"Tính mật độ đường nét (brushwork complexity)\"\"\"\n","    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)\n","    # Dùng Canny để tìm cạnh (nét vẽ)\n","    edges = cv2.Canny(gray, 100, 200)\n","    # Tính tỷ lệ pixel cạnh trên tổng số pixel\n","    density = np.sum(edges) / (img.shape[0] * img.shape[1])\n","    return density\n","\n","def extract_features(image_path, k=5):\n","    \"\"\"\n","    Hàm cốt lõi: Đọc ảnh -> Resize -> K-Means Clustering -> Lấy bảng màu\n","    \"\"\"\n","    img = cv2.imread(image_path)\n","    if img is None: return None\n","\n","    # 1. Tính độ phức tạp đường nét (để phân tích thêm)\n","    edge_density = calculate_edge_density(img)\n","\n","    # 2. Xử lý màu sắc\n","    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","    img_small = cv2.resize(img_rgb, (100, 100))\n","    pixels = img_small.reshape(-1, 3)\n","\n","    # Dùng K-Means để tìm k màu đại diện\n","    kmeans = KMeans(n_clusters=k, n_init=10, random_state=42)\n","    kmeans.fit(pixels)\n","\n","    colors = kmeans.cluster_centers_\n","    labels = kmeans.labels_\n","\n","    counts = np.bincount(labels)\n","    proportions = counts / len(pixels)\n","\n","    sorted_idx = np.argsort(proportions)[::-1]\n","    sorted_colors = colors[sorted_idx]\n","    sorted_props = proportions[sorted_idx]\n","\n","    # Tạo vector đặc trưng màu: [R1, G1, B1, %1, R2, G2, B2, %2, ...]\n","    feature_vector = []\n","    for i in range(k):\n","        feature_vector.extend(sorted_colors[i])\n","        feature_vector.append(sorted_props[i])\n","\n","    return np.array(feature_vector), edge_density"],"metadata":{"id":"bR2zpPipY22m","executionInfo":{"status":"ok","timestamp":1768018825439,"user_tz":-420,"elapsed":4,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":9,"outputs":[]},{"cell_type":"markdown","source":["#CHẠY QUYÉT DỮ LIỆU"],"metadata":{"id":"OKegveycZucq"}},{"cell_type":"code","source":["X_data = [] # Chứa vector đặc trưng màu\n","y_labels = [] # Chứa nhãn (1, 2, 3, 4)\n","raw_stats = {\"sizes\": [], \"edges\": {1:[], 2:[], 3:[], 4:[]}}\n","\n","print(\"\\n Đang phân tích màu sắc và đường nét từng bức tranh...\")\n","\n","for key, config in dataset_config.items():\n","    if config[\"path\"]:\n","        for f in os.listdir(config[\"path\"]):\n","            if f.lower().endswith(('.jpg', '.png', '.jpeg')):\n","                fpath = os.path.join(config[\"path\"], f)\n","\n","                # Thu thập thông tin kích thước cho EDA\n","                img_temp = cv2.imread(fpath)\n","                if img_temp is not None:\n","                    raw_stats[\"sizes\"].append(img_temp.shape[:2])\n","\n","                # Trích xuất đặc trưng\n","                feats, edge_score = extract_features(fpath, k=5)\n","                if feats is not None:\n","                    X_data.append(feats)\n","                    y_labels.append(config[\"label\"])\n","                    raw_stats[\"edges\"][config[\"label\"]].append(edge_score)\n","\n","# Tính trung bình độ phức tạp nét vẽ cho từng họa sĩ\n","for lbl, scores in raw_stats[\"edges\"].items():\n","    avg = np.mean(scores) if scores else 0\n","    # Map ngược lại vào config\n","    for key, val in dataset_config.items():\n","        if val[\"label\"] == lbl:\n","            dataset_config[key][\"avg_edge\"] = avg\n","\n","X_data = np.array(X_data)\n","y_labels = np.array(y_labels)\n","print(f\" Hoàn tất! Đã học được {len(X_data)} tác phẩm.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"J3swY5gIZw24","executionInfo":{"status":"ok","timestamp":1768018845592,"user_tz":-420,"elapsed":17155,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"outputId":"1b356249-51e7-4bc3-c74a-0b841b66407e"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["\n"," Đang phân tích màu sắc và đường nét từng bức tranh...\n"," Hoàn tất! Đã học được 143 tác phẩm.\n"]}]},{"cell_type":"markdown","source":["#HUẤN LUYỆN MÔ HÌNH"],"metadata":{"id":"xXQLVIkpa195"}},{"cell_type":"code","source":["if len(X_data) > 0:\n","    # Sử dụng KNN với weights='distance'\n","    knn = KNeighborsClassifier(n_neighbors=min(5, len(X_data)), weights='distance')\n","    knn.fit(X_data, y_labels)\n","    print(\" Mô hình AI đã được huấn luyện xong (Dựa trên hệ màu).\")\n","else:\n","    print(\" LỖI: Không có dữ liệu để huấn luyện.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2snfyahma3sO","executionInfo":{"status":"ok","timestamp":1768018849526,"user_tz":-420,"elapsed":9,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}},"outputId":"89edf45b-7a5b-462c-ab90-2d18548b4c94"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":[" Mô hình AI đã được huấn luyện xong (Dựa trên hệ màu).\n"]}]},{"cell_type":"markdown","source":["#DỰ ĐOÁN VÀ PHÂN TÍCH ẢNH TEST"],"metadata":{"id":"EBPWloCJbKX6"}},{"cell_type":"code","source":["def analyze_and_predict(image_path):\n","    print(\"\\n\" + \"=\"*50)\n","    print(f\"PHÂN TÍCH BỨC TRANH: {image_path}\")\n","    print(\"=\"*50)\n","\n","    if not os.path.exists(image_path):\n","        print(\" Không tìm thấy file ảnh test. Hãy kiểm tra lại tên file.\")\n","        return\n","\n","    # 1. Hiển thị ảnh gốc\n","    img = cv2.imread(image_path)\n","    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n","\n","    # 2. Lấy đặc trưng\n","    input_feats, input_edge = extract_features(image_path, k=5)\n","\n","    # 3. Dự đoán\n","    pred_label = knn.predict([input_feats])[0]\n","    probs = knn.predict_proba([input_feats])[0]\n","\n","    # 4. Lấy thông tin kết quả\n","    result_info = None\n","    for k, c in dataset_config.items():\n","        if c[\"label\"] == pred_label:\n","            result_info = c\n","            break\n","\n","    print(f\" KẾT LUẬN: Tranh mang phong cách của {result_info['name'].upper()}\")\n","    print(f\"Phong cách điển hình: {result_info['style']}\")\n","    print(f\" Độ tin cậy (Màu sắc): {probs[pred_label-1]*100:.2f}%\")\n","\n","    # So sánh đường nét\n","    print(f\" Phân tích nét vẽ :\")\n","    print(f\"   - Tranh này: {input_edge:.2f}\")\n","    print(f\"   - Trung bình của {result_info['name']}: {result_info['avg_edge']:.2f}\")\n","    if abs(input_edge - result_info['avg_edge']) < 10:\n","        print(\"   => Tương đồng về độ phức tạp nét vẽ.\")\n","    else:\n","        print(\"   => Khác biệt về độ phức tạp nét vẽ (Lưu ý: Mô hình chủ yếu dựa vào màu sắc).\")\n","\n","    # Plotting\n","    plt.figure(figsize=(14, 5))\n","    plt.subplot(1, 3, 1)\n","    plt.imshow(img_rgb)\n","    plt.title(\"Ảnh Input\")\n","    plt.axis('off')\n","\n","    # Bảng màu\n","    plt.subplot(1, 3, 2)\n","    palette_bar = np.zeros((50, 300, 3), dtype=\"uint8\")\n","    curr_x = 0\n","    for i in range(0, len(input_feats), 4):\n","        color = input_feats[i:i+3]\n","        prop = input_feats[i+3]\n","        end_x = curr_x + int(prop * 300)\n","        palette_bar[:, curr_x:end_x] = color\n","        curr_x = end_x\n","    plt.imshow(palette_bar)\n","    plt.title(\"Bảng màu đặc trưng (K-Means)\")\n","    plt.axis('off')\n","\n","    # Biểu đồ xác suất\n","    plt.subplot(1, 3, 3)\n","    names = [c[\"name\"] for k, c in dataset_config.items()]\n","    y_pos = np.arange(len(names))\n","    plt.barh(y_pos, probs, color='skyblue')\n","    plt.yticks(y_pos, names)\n","    plt.xlabel(\"Độ tương đồng màu sắc\")\n","    plt.title(\"So sánh tương đồng\")\n","\n","    plt.tight_layout()\n","    plt.show()"],"metadata":{"id":"gEUsxQN7bR7e","executionInfo":{"status":"ok","timestamp":1768018853925,"user_tz":-420,"elapsed":12,"user":{"displayName":"Hương Giang Nguyễn","userId":"02472263620861935018"}}},"execution_count":12,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":590},"id":"04518a0d","executionInfo":{"status":"ok","timestamp":1765355863540,"user_tz":-420,"elapsed":1900,"user":{"displayName":"24070622 NGUYỄN NGỌC ANH","userId":"02185149549243601521"}},"outputId":"75eda8af-02b5-4975-d699-8cae915a1d25"},"source":["analyze_and_predict(TEST_IMAGE_NAME)"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","==================================================\n","PHÂN TÍCH BỨC TRANH: test.jpg\n","==================================================\n"," KẾT LUẬN: Tranh mang phong cách của TÔ NGỌC VÂN\n","Phong cách điển hình: Sơn dầu (Lãng mạn, ánh sáng phương Tây, gam trắng/xanh)\n"," Độ tin cậy (Màu sắc): 41.26%\n"," Phân tích nét vẽ :\n","   - Tranh này: 27.17\n","   - Trung bình của Tô Ngọc Vân: 23.46\n","   => Tương đồng về độ phức tạp nét vẽ.\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x500 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["#ĐÁNH GIÁ MÔ HÌNH"],"metadata":{"id":"1RtJtIERcq22"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def perform_eda():\n","    print(\" PHÂN TÍCH DỮ LIỆU (EDA) & ĐÁNH GIÁ ĐỘ CHÍNH XÁC\")\n","\n","    if len(X_data) == 0: return\n","\n","    # 1. Thống kê số lượng\n","    unique, counts = np.unique(y_labels, return_counts=True)\n","    names = [c[\"name\"] for c in dataset_config.values()]\n","\n","    plt.figure(figsize=(12, 4))\n","    plt.subplot(1, 3, 1)\n","    sns.barplot(x=names, y=counts, palette=\"viridis\")\n","    plt.title(\"Số lượng tranh mỗi họa sĩ\")\n","    plt.xticks(rotation=45)\n","\n","\n","    # 4. Chấm điểm độ chính xác\n","    print(\"\\n--- ĐANG CHẤM ĐIỂM MÔ HÌNH (Cross-Validation 80/20) ---\")\n","    X_train, X_test, y_train, y_test = train_test_split(X_data, y_labels, test_size=0.2, random_state=42, stratify=y_labels)\n","\n","    val_knn = KNeighborsClassifier(n_neighbors=min(5, len(X_train)), weights='distance')\n","    val_knn.fit(X_train, y_train)\n","    y_pred = val_knn.predict(X_test)\n","\n","    acc = accuracy_score(y_test, y_pred)\n","    print(f\" ĐỘ CHÍNH XÁC TỔNG QUÁT: {acc*100:.2f}%\")\n","    print(\"\\nChi tiết báo cáo:\")\n","    print(classification_report(y_test, y_pred, target_names=names))\n","\n","    # Ma trận nhầm lẫn\n","    cm = confusion_matrix(y_test, y_pred)\n","    plt.figure(figsize=(6, 5))\n","    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=names, yticklabels=names)\n","    plt.title(\"Ma trận nhầm lẫn (Confusion Matrix)\")\n","    plt.xlabel(\"Máy dự đoán\")\n","    plt.ylabel(\"Thực tế\")\n","    plt.show()\n","\n","# Chạy phân tích EDA\n","perform_eda()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"PtrPIkzYcwqW","executionInfo":{"status":"ok","timestamp":1765355863643,"user_tz":-420,"elapsed":94,"user":{"displayName":"24070622 NGUYỄN NGỌC ANH","userId":"02185149549243601521"}},"outputId":"c65688a8-58e3-435a-8d3e-134a60ea4593"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":[" PHÂN TÍCH DỮ LIỆU (EDA) & ĐÁNH GIÁ ĐỘ CHÍNH XÁC\n","\n","--- ĐANG CHẤM ĐIỂM MÔ HÌNH (Cross-Validation 80/20) ---\n"," ĐỘ CHÍNH XÁC TỔNG QUÁT: 41.38%\n","\n","Chi tiết báo cáo:\n","                  precision    recall  f1-score   support\n","\n","  Nguyễn Gia Trí       0.00      0.00      0.00         6\n","Nguyễn Tường Lân       0.00      0.00      0.00         4\n","     Tô Ngọc Vân       0.50      0.67      0.57         9\n","    Trần Văn Cẩn       0.43      0.60      0.50        10\n","\n","        accuracy                           0.41        29\n","       macro avg       0.23      0.32      0.27        29\n","    weighted avg       0.30      0.41      0.35        29\n","\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-2146656806.py:12: FutureWarning: \n","\n","Passing `palette` without assigning `hue` is deprecated and will be removed in v0.14.0. Assign the `x` variable to `hue` and set `legend=False` for the same effect.\n","\n","  sns.barplot(x=names, y=counts, palette=\"viridis\")\n","/usr/local/lib/python3.12/dist-packages/sklearn/metrics/_classification.py:1565: UndefinedMetricWarning: Precision is ill-defined and being set to 0.0 in labels with no predicted samples. Use `zero_division` parameter to control this behavior.\n","  _warn_prf(average, modifier, f\"{metric.capitalize()} is\", len(result))\n","/usr/local/lib/python3.12/dist-packages/sklearn/metrics/_classification.py:1565: UndefinedMetricWarning: Precision is ill-defined and being set to 0.0 in labels with no predicted samples. Use `zero_division` parameter to control this behavior.\n","  _warn_prf(average, modifier, f\"{metric.capitalize()} is\", len(result))\n","/usr/local/lib/python3.12/dist-packages/sklearn/metrics/_classification.py:1565: UndefinedMetricWarning: Precision is ill-defined and being set to 0.0 in labels with no predicted samples. Use `zero_division` parameter to control this behavior.\n","  _warn_prf(average, modifier, f\"{metric.capitalize()} is\", len(result))\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x400 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x500 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import seaborn as sns\n","import numpy as np\n","import cv2\n","def visualize_dataset_analysis():\n","    print(\"TRỰC QUAN HÓA DỮ LIỆU DATASET (EDA)\")\n","\n","    if len(X_data) == 0:\n","        print(\" Chưa có dữ liệu để vẽ. Vui lòng chạy phần trích xuất đặc trưng trước.\")\n","        return\n","\n","    # Thiết lập style cho biểu đồ đẹp hơn\n","    sns.set_style(\"whitegrid\")\n","\n","    # Lấy dữ liệu cần thiết\n","    unique, counts = np.unique(y_labels, return_counts=True)\n","    names = [c[\"name\"] for c in dataset_config.values()]\n","    colors_map = ['#8c564b', '#e377c2', '#1f77b4', '#ff7f0e'] # Nâu, Hồng, Xanh, Cam\n","\n","    # TẠO KHUNG VẼ LỚN (2 Hàng x 2 Cột)\n","    fig = plt.figure(figsize=(16, 10))\n","    fig.suptitle('PHÂN TÍCH ĐẶC ĐIỂM TRANH TỨ LÂN VÂN CẨN', fontsize=16, fontweight='bold')\n","\n","    #  1. BIỂU ĐỒ TRÒN: TỶ LỆ SỐ LƯỢNG TRANH ---\n","    ax1 = fig.add_subplot(2, 2, 1)\n","    ax1.pie(counts, labels=names, autopct='%1.1f%%', startangle=140, colors=colors_map,\n","            wedgeprops={'edgecolor': 'white', 'linewidth': 2})\n","    ax1.set_title(\"1. Tỷ lệ phân bố dữ liệu trong Dataset\", fontweight='bold')\n","\n","    # 2. BIỂU ĐỒ HỘP: ĐỘ PHỨC TẠP NÉT VẼ (EDGE DENSITY) ---\n","    ax2 = fig.add_subplot(2, 2, 2)\n","\n","    # Chuẩn bị dữ liệu cho Boxplot\n","    edge_data = []\n","    edge_labels = []\n","    for lbl, scores in raw_stats[\"edges\"].items():\n","        edge_data.extend(scores)\n","        # Tìm tên họa sĩ tương ứng với label\n","        name = \"\"\n","        for k, c in dataset_config.items():\n","            if c[\"label\"] == lbl: name = c[\"name\"]\n","        edge_labels.extend([name]*len(scores))\n","\n","    sns.boxplot(x=edge_labels, y=edge_data, palette=colors_map, ax=ax2)\n","    ax2.set_title(\"2. Độ phức tạp chi tiết/nét vẽ (Texture Complexity)\", fontweight='bold')\n","    ax2.set_ylabel(\"Mật độ cạnh (Edge Density)\")\n","    ax2.grid(True, linestyle='--', alpha=0.6)\n","\n","    # 3. BIỂU ĐỒ TÁN XẠ: KÍCH THƯỚC ẢNH\n","    ax3 = fig.add_subplot(2, 2, 3)\n","    if raw_stats[\"sizes\"]:\n","        h, w = zip(*raw_stats[\"sizes\"])\n","        ax3.scatter(w, h, alpha=0.6, c='purple', s=50, edgecolors='w')\n","        ax3.set_title(\"3. Phân bố độ phân giải ảnh gốc\", fontweight='bold')\n","        ax3.set_xlabel(\"Chiều rộng (Width)\")\n","        ax3.set_ylabel(\"Chiều cao (Height)\")\n","    else:\n","        ax3.text(0.5, 0.5, \"Không có dữ liệu size\", ha='center')\n","\n","    #  4. DẢI MÀU TRUNG BÌNH\n","    ax4 = fig.add_subplot(2, 2, 4)\n","    ax4.axis('off')\n","    ax4.set_title(\"4. Bảng màu đặc trưng trung bình của từng họa sĩ\", fontweight='bold')\n","\n","    # Vẽ các dải màu con bên trong ax4\n","    y_offset = 0.8\n","    for idx, (key, config) in enumerate(dataset_config.items()):\n","        lbl = config[\"label\"]\n","        # Lấy tất cả vector màu của họa sĩ này từ X_data\n","        artist_features = X_data[y_labels == lbl]\n","\n","        if len(artist_features) > 0:\n","            # Tính trung bình cộng các vector đặc trưng\n","            mean_feature = np.mean(artist_features, axis=0)\n","\n","            # Tách lại thành bảng màu (5 màu chủ đạo trung bình)\n","            mean_palette = []\n","            mean_props = []\n","            for i in range(0, len(mean_feature), 4):\n","                mean_palette.append(mean_feature[i:i+3]) # RGB\n","                mean_props.append(mean_feature[i+3])     # Tỷ lệ\n","\n","            # Vẽ dải màu\n","            bar_x = 0\n","            bar_y = y_offset - (idx * 0.2)\n","            bar_height = 0.15\n","\n","            # Label tên\n","            ax4.text(-0.1, bar_y + bar_height/2, config[\"name\"],\n","                     va='center', ha='right', fontsize=10, fontweight='bold')\n","\n","            # Vẽ từng đoạn màu\n","            current_x = 0\n","            for color, prop in zip(mean_palette, mean_props):\n","                # Chuẩn hóa màu về 0-1 để vẽ\n","                c_norm = np.array(color) / 255.0\n","                ax4.barh(bar_y, prop, left=current_x, height=bar_height, color=c_norm, edgecolor='none')\n","                current_x += prop\n","\n","    plt.tight_layout()\n","    plt.show()\n","\n","# Gọi hàm để vẽ\n","visualize_dataset_analysis()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":813},"id":"HDMk5n12dN2m","executionInfo":{"status":"ok","timestamp":1765355863836,"user_tz":-420,"elapsed":191,"user":{"displayName":"24070622 NGUYỄN NGỌC ANH","userId":"02185149549243601521"}},"outputId":"bb20d5fb-2ade-46ac-dc93-44833cc5b22d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["TRỰC QUAN HÓA DỮ LIỆU DATASET (EDA)\n"]},{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-1758434780.py:44: FutureWarning: \n","\n","Passing `palette` without assigning `hue` is deprecated and will be removed in v0.14.0. Assign the `x` variable to `hue` and set `legend=False` for the same effect.\n","\n","  sns.boxplot(x=edge_labels, y=edge_data, palette=colors_map, ax=ax2)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x1000 with 4 Axes>"],"image/png":"\n"},"metadata":{}}]}],"metadata":{"colab":{"provenance":[{"file_id":"/v2/external/notebooks/intro.ipynb","timestamp":1764817041365}]},"kernelspec":{"display_name":"Python 3","name":"python3"}},"nbformat":4,"nbformat_minor":0}